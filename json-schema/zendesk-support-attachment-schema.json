{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Attachment",
  "type": "object",
  "description": "A file attachment.",
  "properties": {
    "id": {
      "type": "integer"
    },
    "file_name": {
      "type": "string"
    },
    "content_url": {
      "type": "string"
    },
    "content_type": {
      "type": "string"
    },
    "size": {
      "type": "integer",
      "description": "The size of the file in bytes."
    },
    "thumbnails": {
      "type": "array"
    }
  }
}