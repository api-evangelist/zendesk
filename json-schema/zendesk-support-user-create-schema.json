{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserCreate",
  "type": "object",
  "description": "Payload for creating a new user.",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the user."
    },
    "email": {
      "type": "string",
      "description": "The user's email address."
    },
    "phone": {
      "type": "string",
      "description": "The user's phone number."
    },
    "role": {
      "type": "string"
    },
    "custom_role_id": {
      "type": "integer"
    },
    "organization_id": {
      "type": "integer"
    },
    "external_id": {
      "type": "string"
    },
    "tags": {
      "type": "array"
    },
    "locale_id": {
      "type": "integer"
    },
    "time_zone": {
      "type": "string"
    },
    "details": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "alias": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "verified": {
      "type": "boolean"
    },
    "user_fields": {
      "type": "object"
    }
  }
}