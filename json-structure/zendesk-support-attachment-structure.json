{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Attachment",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "file_name": {
      "type": "string"
    },
    "content_url": {
      "type": "string"
    },
    "content_type": {
      "type": "string"
    },
    "size": {
      "type": "integer"
    },
    "thumbnails": {
      "type": "array"
    }
  }
}